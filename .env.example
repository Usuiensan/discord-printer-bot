DISCORD_TOKEN=fFtskjwwRMv8F7zUN4B6tsZ6NVs9zOqI
DISCORD_CHANNEL_ID=1513044471275589752

# Optional. If set, slash commands are registered to this guild immediately.
# If blank, commands are registered globally and may take time to appear.
DISCORD_GUILD_ID=1507235720912179200

# Printer backend: windows, bridge, or linux-usb.
# windows uses local PowerShell/Winspool, bridge sends to the Windows print bridge,
# linux-usb writes ESC/POS bytes directly to a Debian/Linux USB printer device.
PRINTER_BACKEND=windows

# Windows printer queue name, for example: EPSON TM-T70II Receipt.
# Optional when PRINTER_BACKEND=linux-usb.
PRINTER_NAME=EPSON TM-T70II Receipt

# Debian bot mode: send print jobs to the Windows OPOS/print bridge instead of local PowerShell.
# Leave PRINT_BRIDGE_URL blank when running the bot directly on Windows.
PRINT_BRIDGE_URL=
PRINT_BRIDGE_TOKEN=

# Windows bridge mode: listen address and port for npm run bridge.
PRINT_BRIDGE_HOST=0.0.0.0
PRINT_BRIDGE_PORT=8787

# Debian CT linux-usb mode. Pass the TM-T70II USB device through to the CT first.
LINUX_PRINTER_DEVICE=/dev/usb/lp0
LINUX_STATUS_ENABLED=true
LINUX_STATUS_TIMEOUT_MS=1000

# Retry when Windows reports a transient printer state such as "deleting/aborting previous job".
PRINT_RETRY_ATTEMPTS=8
PRINT_RETRY_DELAY_MS=5000

# Periodically notify Discord when paper out, cover open, offline, etc. is detected.
PRINTER_MONITOR_ENABLED=true
PRINTER_MONITOR_INTERVAL_MS=1000

# Print a receipt when a new member joins the configured guild.
# Requires Server Members Intent in Discord Developer Portal.
MEMBER_JOIN_PRINT_ENABLED=true

# Optional OPOS ADK for .NET status checks. Configure the logical name in SetupPOS first.
OPOS_STATUS_ENABLED=true
OPOS_LOGICAL_NAME=TM-T70II
OPOS_CLAIM_TIMEOUT_MS=1000

# TM-T70II 58mm is commonly 384 dots. Change only if your printer driver uses a different printable width.
PRINT_WIDTH_DOTS=384

# true: cut paper after each Discord message. false: leave paper uncut.
CUT_AFTER_PRINT=true

# none, partial, partial3, or full. partial is recommended for TM-T70II.
# CUT_AFTER_PRINT=false is treated like CUT_MODE=none.
CUT_MODE=full

# true: print a small header with author and time before the body.
PRINT_HEADER=true

# If the same user posts again within this many milliseconds, omit the repeated header.
MERGE_SAME_USER_WINDOW_MS=3000

# true: print the Discord author's avatar before the message header.
PRINT_AUTHOR_AVATAR=true

# Avatar image width in printer dots. 96 is about 12mm at 203dpi.
AUTHOR_AVATAR_WIDTH_DOTS=96

# Font used for Discord header images and preview images.
# On Debian CT, install fonts-vlgothic and keep this default.
PRINT_FONT_PATH=/usr/share/fonts/truetype/vlgothic/VL-Gothic-Regular.ttf
PRINT_FONT_FAMILY=VL Gothic

# CP932で表せない簡体字・ピンイン等の印字方法。
# auto: 1文字でも対象なら印刷ジョブ内の全テキストを画像化、image: 常に全テキストを画像化。
TEXT_RENDER_MODE=auto
# Debian: apt install fonts-noto-cjk
TEXT_IMAGE_FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc
TEXT_IMAGE_FONT_FAMILY=Noto Sans Mono CJK JP
TEXT_IMAGE_FONT_SIZE_DOTS=28
TEXT_IMAGE_LINE_HEIGHT_DOTS=30
# 各行の下に追加する余白。30+6=36ドット間隔になる。
TEXT_IMAGE_LINE_GAP_DOTS=6
# 文字画像だけ完全2値化する。通常画像はIMAGE_DITHER_MODEを使う。
TEXT_IMAGE_DITHER_MODE=threshold
TEXT_IMAGE_THRESHOLD=170

# !cutとReceiptLineの途中カット前後に入れる空行数。
CUT_FEED_LINES=3

# Image conversion mode. ordered simulates grayscale with halftone dots. threshold is simple black/white.
IMAGE_DITHER_MODE=ordered

# Maximum image download size in bytes. Images are resized to printer width before printing.
IMAGE_MAX_BYTES=33554432

# Maximum text attachment download size in bytes.
TEXT_ATTACHMENT_MAX_BYTES=262144

# URL QR behavior.
# manual: normal URLs are printed as text only. Use !qr or !print-code qr when QR is needed.
# auto: also print detected http/https URLs as printer-native QR codes.
URL_QR_MODE=manual

# Legacy compatibility. Used only when URL_QR_MODE is not set.
PRINT_URL_QR=false

# Emoji rendering: inline_image, alias_append, or text.
# inline_image inserts each emoji image where it appeared in the message.
# alias_append prints :emoji_name: in text and appends deduplicated emoji images at the end.
# text prints only the text alias.
EMOJI_RENDER_MODE=inline_image

# Inline emoji image width in printer dots.
EMOJI_IMAGE_WIDTH_DOTS=128

# QR module size. 4-8 is usually readable on 58mm paper.
QR_MODULE_SIZE=6

# QR error correction: L, M, Q, or H.
QR_ERROR_CORRECTION=M

# 1D barcode human-readable text: none, above, below, or both.
# Use none to avoid printing the text under barcodes.
BARCODE_HRI=below

# Text command prefix used as a slash-command fallback.
# Examples: !qr https://example.com, !print-code code128 ABC123
MESSAGE_COMMAND_PREFIX=!

# Advanced: allow selected Discord users to submit raw ESC/POS hex bytes.
# Leave blank to disable. Comma-separated Discord user IDs.
RAW_ESCPOS_USER_IDS=

# Extra-strict allowlist for raw ESC/POS commands that may query status or change device settings.
RAW_ESCPOS_ADMIN_USER_IDS=

# Maximum raw ESC/POS payload size in bytes.
RAW_ESCPOS_MAX_BYTES=4096

# Reaction added by the bot after the print job finishes successfully.
# Unicode emoji like ✅ or custom emoji format name:id can be used.
PRINTED_REACTION=✅

# Reaction added after successful printing when the receipt paper is near end.
PRINT_NEAR_END_REACTION=🧻

# Reaction added if printing failed or completed with skipped content.
PRINT_ERROR_REACTION=⚠️

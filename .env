DISCORD_TOKEN=MTQ4NzQ3ODc2NzE0NzI4Njc4OQ.GbsTpC.vSzitpyEH5gxBIdTbVfBniDlwT1T2lf-emja_8
DISCORD_CHANNEL_ID=1513044471275589752
DISCORD_GUILD_ID=1507235720912179200

# Windows printer queue name, for example: EPSON TM-T70II Receipt
PRINTER_NAME=EPSON TM-T70II Receipt

# Optional OPOS ADK for .NET status checks. Configure the logical name in SetupPOS first.
OPOS_STATUS_ENABLED=false
OPOS_LOGICAL_NAME=TM-T70II
OPOS_CLAIM_TIMEOUT_MS=1000

# TM-T70II 58mm is commonly 384 dots. Change only if your printer driver uses a different printable width.
PRINT_WIDTH_DOTS=384

# true: cut paper after each Discord message. false: leave paper uncut.
CUT_AFTER_PRINT=true

# none, partial, or full. partial is recommended for TM-T70II.
# CUT_AFTER_PRINT=false is treated like CUT_MODE=none.
CUT_MODE=full

# true: print a small header with author and time before the body.
PRINT_HEADER=true

# If the same user posts again within this many milliseconds, omit the repeated header.
MERGE_SAME_USER_WINDOW_MS=3000

# true: print the Discord author's avatar before the message header.
PRINT_AUTHOR_AVATAR=true

# Avatar image width in printer dots. 96 is about 12mm at 203dpi.
AUTHOR_AVATAR_WIDTH_DOTS=203

# Image conversion mode. ordered simulates grayscale with halftone dots. threshold is simple black/white.
IMAGE_DITHER_MODE=ordered

# Maximum image download size in bytes. Images are resized to printer width before printing.
IMAGE_MAX_BYTES=33554432

# true: print detected http/https URLs as printer-native QR codes.
PRINT_URL_QR=true

# QR module size. 4-8 is usually readable on 58mm paper.
QR_MODULE_SIZE=6

# QR error correction: L, M, Q, or H.
QR_ERROR_CORRECTION=M

# Text command prefix used as a slash-command fallback.
# Examples: !qr https://example.com, !print-code code128 ABC123
MESSAGE_COMMAND_PREFIX=!

# Reaction added by the bot after the print job finishes successfully.
# Unicode emoji like ✅ or custom emoji format name:id can be used.
PRINTED_REACTION=✅

# Reaction added if printing failed or completed with skipped content.
PRINT_ERROR_REACTION=⚠️
